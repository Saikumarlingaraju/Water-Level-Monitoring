# Backend Environment Variables

# Aiven PostgreSQL Connection
DB_HOST=your-host.aivencloud.com
DB_PORT=12345
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your-password
DB_SSLMODE=require

# Optional model metadata shown by /api/v1/model-info
MODEL_VERSION=1.0
MODEL_ACCURACY=0.85
MODEL_CLASSES=no_activity,shower,faucet,toilet,dishwasher

# Frontend origins allowed to call the backend in production
# Example: https://your-frontend.vercel.app,https://your-site.netlify.app
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional regex for preview and wildcard frontends, for example Vercel preview domains
CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app

# Runtime toggles
TEST_MODE=true
ENABLE_SENSOR_COLLECTOR=true
SENSOR_POLL_SECONDS=20

# Authentication
AUTH_SECRET_KEY=change-this-secret-in-production
AUTH_TOKEN_EXPIRE_MINUTES=720

# Email alerts for anomaly detection
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_FROM=alerts@example.com
ALERT_EMAIL_TO=receiver@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
ALERT_COOLDOWN_MINUTES=30
CRITICAL_WATER_LEVEL_PERCENT=15
HIGH_TEMPERATURE_C=35
MAX_DISTANCE_CM=220
ALERT_PREDICTION_LABELS=flush,geyser,washing_machine