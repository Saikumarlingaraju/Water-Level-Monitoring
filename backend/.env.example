# Backend Environment Variables

# Aiven PostgreSQL Connection
DB_HOST=your-host.aivencloud.com
DB_PORT=12345
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your-password
DB_SSLMODE=require

# Optional model metadata shown by /api/v1/model-info
MODEL_VERSION=1.0
MODEL_ACCURACY=0.85
MODEL_CLASSES=no_activity,shower,faucet,toilet,dishwasher

# Frontend origins allowed to call the backend in production
# Example: https://your-frontend.vercel.app,https://your-site.netlify.app
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Runtime toggles
TEST_MODE=true
ENABLE_SENSOR_COLLECTOR=true
SENSOR_POLL_SECONDS=20